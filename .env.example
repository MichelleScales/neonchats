# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://emp:emp@localhost:5432/emp
DATABASE_SYNC_URL=postgresql://emp:emp@localhost:5432/emp

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth (JWT — replace with Keycloak in production) ─────────────────────────
SECRET_KEY=changeme-use-a-long-random-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── AI Model Providers ────────────────────────────────────────────────────────
# Moonshot AI (Kimi) — default provider
MOONSHOT_API_KEY=sk-...
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
DEFAULT_MODEL_PROVIDER=moonshot          # moonshot | anthropic | openai
DEFAULT_EXTERNAL_MODEL=moonshot-v1-8k   # moonshot-v1-8k | moonshot-v1-32k | moonshot-v1-128k

# Optional: Anthropic / OpenAI fallbacks
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Integrations ──────────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG....
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
HUBSPOT_ACCESS_TOKEN=pat-...

# ── App Settings ──────────────────────────────────────────────────────────────
APP_ENV=development                       # development | staging | production
APP_URL=http://localhost:3000
API_URL=http://localhost:8000
CORS_ORIGINS=["http://localhost:3000"]

# ── Object Storage (MinIO / S3) ───────────────────────────────────────────────
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=emp-assets
